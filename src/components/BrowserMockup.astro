---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["browser-mockup rounded-2xl border border-[#e5e3dc] overflow-hidden", className]}>
  <!-- Title bar with traffic lights -->
  <div class="browser-titlebar flex items-center px-4 h-9 bg-[#f5f5f3] border-b border-[#e5e3dc]">
    <div class="flex items-center gap-2">
      <span class="block w-[10px] h-[10px] rounded-full bg-[#ff5f56]"></span>
      <span class="block w-[10px] h-[10px] rounded-full bg-[#ffbd2e]"></span>
      <span class="block w-[10px] h-[10px] rounded-full bg-[#27c93f]"></span>
    </div>
  </div>
  <!-- Content area -->
  <div class="browser-content bg-white overflow-hidden">
    <slot />
  </div>
</div>

<style>
  .browser-mockup {
    box-shadow: 0 24px 48px rgba(196, 112, 75, 0.08);
  }
</style>
