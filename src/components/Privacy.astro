---
const specs = [
  {
    title: 'IndexedDB Storage',
    description: 'All financial data persists in your browser\'s IndexedDB. Private, encrypted, and accessible only to you.',
    icon: 'database',
  },
  {
    title: 'Local-Only Processing',
    description: 'AI analysis runs entirely in your browser session. No data is transmitted to external servers for processing.',
    icon: 'cpu',
  },
  {
    title: 'No Data Network Calls',
    description: 'NeoCash makes zero network requests with your financial data. Your information stays in your browser tab.',
    icon: 'wifi-off',
  },
  {
    title: 'Browser-Native Security',
    description: 'Built on web platform security primitives. Same-origin policy, sandboxed execution, and standard browser protections.',
    icon: 'globe',
  },
];
---

<section id="privacy" class="relative bg-bg-dark py-20 md:py-32">
  <!-- Copper gradient line at top -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>

  <div class="mx-auto max-w-[1280px] px-6">
    <!-- Section header -->
    <div class="text-center" data-animate>
      <span class="font-mono text-xs text-accent uppercase tracking-[0.2em]">
        Privacy by Design
      </span>
      <h2 class="font-display text-3xl md:text-[48px] md:leading-tight text-text-light text-center mt-4 font-normal">
        Zero servers. Zero accounts. Zero compromises.
      </h2>
      <p class="font-body text-lg text-text-light/70 text-center max-w-2xl mx-auto mt-6">
        Your financial data never leaves your browser. Not to our servers. Not to anyone's servers. Not ever.
      </p>
    </div>

    <!-- Technical specs grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-16" data-animate>
      {specs.map((spec) => (
        <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
          <!-- Icon -->
          <div class="mb-4 text-accent">
            {spec.icon === 'database' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3" />
                <path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5" />
                <path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3" />
              </svg>
            )}
            {spec.icon === 'cpu' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="4" width="16" height="16" rx="2" />
                <rect x="9" y="9" width="6" height="6" rx="1" />
                <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3" />
              </svg>
            )}
            {spec.icon === 'wifi-off' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 1l22 22" />
                <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55" />
                <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39" />
                <path d="M10.71 5.05A16 16 0 0 1 22.56 9" />
                <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88" />
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0" />
                <circle cx="12" cy="20" r="1" fill="currentColor" />
              </svg>
            )}
            {spec.icon === 'globe' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
            )}
          </div>
          <!-- Title -->
          <h3 class="font-mono text-sm text-text-light font-medium">
            {spec.title}
          </h3>
          <!-- Description -->
          <p class="font-body text-sm text-text-light/60 mt-2 leading-relaxed">
            {spec.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
