---
import { Image } from 'astro:assets';
import BrowserMockup from './BrowserMockup.astro';
import heroImg from '../assets/screenshots/desktop/01-new-chat.png';
---

<section id="hero" class="pt-24 pb-16 md:pt-32 md:pb-20">
  <div class="mx-auto max-w-[1280px] px-6">
    <!-- Headline -->
    <h1 class="font-display text-4xl md:text-[56px] md:leading-tight text-center text-text font-normal">
      Your money. Your data. Your device.
    </h1>

    <!-- Subtitle -->
    <p class="font-body text-lg md:text-xl text-text-muted text-center max-w-xl mx-auto mt-6">
      Personal wealth management, without the institution.
    </p>

    <!-- CTA Button -->
    <div class="mt-10 text-center">
      <a
        href="https://github.com/navam-io/neocash?tab=readme-ov-file#quick-start"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-white rounded-full px-8 py-3.5 text-base font-medium hover:bg-accent-hover transition-all duration-200 shadow-warm-sm hover:shadow-warm"
      >
        Start Managing Your Wealth
      </a>
    </div>

    <!-- Quick Start Terminal -->
    <div class="max-w-2xl mx-auto mt-12">
      <div class="bg-bg-dark rounded-xl border border-accent/15 shadow-warm-lg overflow-hidden">
        <!-- Terminal title bar -->
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-white/5">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-2 text-xs font-mono text-white/30">Terminal</span>
        </div>
        <!-- Terminal body -->
        <div class="px-5 py-4 font-mono text-sm leading-relaxed">
          <p><span class="text-accent">$</span> <span class="text-white/85">git clone https://github.com/manavsehgal/neocash.git</span></p>
          <p><span class="text-accent">$</span> <span class="text-white/85">cd neocash</span></p>
          <p><span class="text-accent">$</span> <span class="text-white/85">cp .env.example .env.local</span>  <span class="text-accent/60"># add your Anthropic API key</span></p>
          <p><span class="text-accent">$</span> <span class="text-white/85">npm install</span></p>
          <p><span class="text-accent">$</span> <span class="text-white/85">npm run dev</span></p>
        </div>
      </div>
    </div>

    <!-- Screenshot area -->
    <div class="relative max-w-6xl mx-auto mt-16" style="width: 80%;">
      <!-- Copper radial glow behind mockup -->
      <div class="absolute -inset-10 rounded-3xl -z-10 blur-3xl" style="background: radial-gradient(ellipse at center, rgba(196, 112, 75, 0.06), transparent);"></div>

      <BrowserMockup>
        <Image src={heroImg} alt="NeoCash AI wealth management dashboard showing new chat with financial categories" class="w-full" />
      </BrowserMockup>
    </div>
  </div>
</section>
