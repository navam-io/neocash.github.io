<section id="cta" class="bg-bg py-20 md:py-32">
  <div class="mx-auto max-w-[800px] px-6" data-animate>
    <!-- Decorative copper rule -->
    <hr class="border-accent/10 max-w-lg mx-auto mb-16" />

    <!-- Headline -->
    <h2 class="font-display text-3xl md:text-[44px] md:leading-tight text-text text-center font-normal">
      Your financial story starts here.
    </h2>

    <!-- CTA button -->
    <div class="mt-8 text-center">
      <a
        href="#hero"
        class="inline-block bg-accent text-white rounded-full px-10 py-4 text-lg font-medium hover:bg-accent-hover transition-all duration-200 shadow-warm hover:shadow-warm-lg"
      >
        Get Started — It's Free
      </a>
    </div>

    <!-- Secondary text -->
    <p class="font-body text-sm text-text-muted text-center mt-4">
      No sign-up. No accounts. Just open and start.
    </p>
  </div>
</section>
