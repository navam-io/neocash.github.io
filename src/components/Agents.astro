---
const agents = [
  {
    name: 'Tax Advisor',
    description:
      'Analyzes tax implications across your entire portfolio. Identifies deductions, optimizes timing, and ensures your wealth strategy is tax-efficient.',
    icon: 'tax',
  },
  {
    name: 'Portfolio Analyzer',
    description:
      'Deep analysis of your investment holdings. Evaluates risk exposure, asset allocation, and performance against your stated goals.',
    icon: 'portfolio',
  },
  {
    name: 'Budget Planner',
    description:
      'Transforms spending data into actionable plans. Tracks cash flow, identifies savings opportunities, and aligns daily spending with long-term goals.',
    icon: 'budget',
  },
  {
    name: 'Estate Planner',
    description:
      'Plans for the long view. Evaluates beneficiary structures, trust options, and succession strategies to protect your legacy.',
    icon: 'estate',
  },
  {
    name: 'Generalist',
    description:
      'Your go-to for everything else. Handles broad financial questions, coordinates between specialists, and provides holistic wealth perspective.',
    icon: 'generalist',
  },
];
---

<section id="agents" class="bg-bg-alt py-16 md:py-24">
  <div class="mx-auto max-w-[1280px] px-6">
    <!-- Section header -->
    <div class="text-center">
      <span class="font-mono text-xs text-accent uppercase tracking-[0.2em]">
        The Agent System
      </span>
      <h2 class="font-display text-3xl md:text-[44px] md:leading-[1.2] text-text mt-4">
        Five experts, one conversation
      </h2>
      <p class="font-body text-lg text-text-muted max-w-2xl mx-auto mt-4">
        Specialized AI agents collaborate behind the scenes to give you
        institutional-grade financial analysis.
      </p>
    </div>

    <!-- Agent cards -->
    <div class="flex flex-wrap justify-center gap-6 mt-12">
      {agents.map((agent, index) => (
        <div
          class="w-full sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] bg-white rounded-2xl p-6 border border-[#e5e3dc] shadow-warm-sm hover:shadow-warm transition-shadow duration-300"
          data-animate
          style={`transition-delay: ${index * 100}ms;`}
        >
          {/* Icon */}
          <div class="h-12 w-12 rounded-xl bg-accent/10 flex items-center justify-center">
            {agent.icon === 'tax' && (
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 11.625h4.5m-4.5 2.25h4.5m2.121-4.476a9 9 0 1 0-4.242 0M12 18.75V21m0 0h-1.5m1.5 0h1.5" />
              </svg>
            )}
            {agent.icon === 'portfolio' && (
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
              </svg>
            )}
            {agent.icon === 'budget' && (
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3" />
              </svg>
            )}
            {agent.icon === 'estate' && (
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
            )}
            {agent.icon === 'generalist' && (
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z" />
              </svg>
            )}
          </div>

          {/* Agent name */}
          <h3 class="font-display text-xl text-text mt-4">{agent.name}</h3>

          {/* Description */}
          <p class="font-body text-sm text-text-muted mt-2 leading-relaxed">
            {agent.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
