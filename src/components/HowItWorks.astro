---
const steps = [
  {
    number: '1',
    title: 'Upload your documents',
    description:
      'Drop in tax returns, bank statements, investment reports, or any financial document. NeoCash processes everything locally in your browser.',
  },
  {
    number: '2',
    title: 'Ask anything',
    description:
      'Chat naturally about your finances. Five specialized AI agents collaborate to provide comprehensive, personalized analysis.',
  },
  {
    number: '3',
    title: 'Get connected insights',
    description:
      'Receive actionable recommendations that account for your complete financial picture. Every goal informs every other.',
  },
];
---

<section id="how-it-works" class="bg-bg py-16 md:py-24">
  <div class="mx-auto max-w-[1280px] px-6">
    <!-- Section header -->
    <div class="text-center">
      <span class="font-mono text-xs text-accent uppercase tracking-[0.2em]">
        How It Works
      </span>
      <h2 class="font-display text-3xl md:text-[44px] md:leading-[1.2] text-text mt-4">
        Three steps. Zero complexity.
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mt-12 relative" data-animate>
      {steps.map((step, index) => (
        <div class="relative text-center">
          {/* Numbered circle */}
          <div class="mx-auto h-12 w-12 rounded-full bg-accent text-white font-display text-xl flex items-center justify-center">
            {step.number}
          </div>

          {/* Step title */}
          <h3 class="font-display text-xl text-text mt-5">{step.title}</h3>

          {/* Step description */}
          <p class="font-body text-sm text-text-muted mt-2 leading-relaxed">
            {step.description}
          </p>

          {/* Arrow connector (desktop only, after steps 1 and 2) */}
          {index < steps.length - 1 && (
            <div class="hidden md:flex absolute top-6 -right-6 md:-right-[calc(1.5rem+1px)] items-center justify-center" aria-hidden="true">
              <svg class="h-5 w-5 text-accent/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
