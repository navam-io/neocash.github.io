<section class="trust-bar bg-bg-alt py-6 border-t border-b border-accent/10">
  <div class="mx-auto max-w-[1280px] px-6 flex items-center justify-center gap-3">
    <!-- Shield icon left -->
    <svg class="shrink-0 w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      <path d="M9 12l2 2 4-4" />
    </svg>

    <!-- Trust message -->
    <p class="font-display italic text-lg max-md:text-base text-text-muted tracking-wide text-center">
      No cloud. No accounts. No data leaves your device.
    </p>

    <!-- Shield icon right -->
    <svg class="shrink-0 w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      <path d="M9 12l2 2 4-4" />
    </svg>
  </div>
</section>
