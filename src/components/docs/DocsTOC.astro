---
interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocItem[];
}

const { headings } = Astro.props;
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{tocItems.length > 0 && (
  <aside class="hidden xl:block w-[200px] shrink-0">
    <nav class="sticky top-20 max-h-[calc(100vh-5rem)] overflow-y-auto">
      <h4 class="font-body font-semibold text-xs uppercase tracking-[0.1em] text-text-muted/70 mb-3">
        On this page
      </h4>
      <ul class="space-y-1 border-l border-[#e5e3dc]">
        {tocItems.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block text-sm text-text-muted hover:text-accent transition-colors duration-150 border-l-2 border-transparent hover:border-accent/40',
                heading.depth === 2 ? 'pl-3 py-1' : 'pl-5 py-0.5 text-xs',
              ]}
              data-toc-link={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script>
  function initScrollSpy() {
    const links = document.querySelectorAll('[data-toc-link]');
    if (!links.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((link) => {
              link.classList.remove('text-accent', 'border-accent', 'font-medium');
              link.classList.add('text-text-muted', 'border-transparent');
            });
            const active = document.querySelector(`[data-toc-link="${entry.target.id}"]`);
            if (active) {
              active.classList.remove('text-text-muted', 'border-transparent');
              active.classList.add('text-accent', 'border-accent', 'font-medium');
            }
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    links.forEach((link) => {
      const id = (link as HTMLElement).dataset.tocLink;
      const target = id ? document.getElementById(id) : null;
      if (target) observer.observe(target);
    });
  }
  initScrollSpy();
  document.addEventListener('astro:after-swap', initScrollSpy);
</script>
