---
interface Props {
  currentPath?: string;
}

const { currentPath } = Astro.props;
---

<nav class="sticky top-0 z-50 h-16 border-b border-[#e5e3dc] transition-all duration-300" style="background-color: rgba(250, 249, 245, 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
  <div class="mx-auto max-w-[1400px] px-6 h-full flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="font-display font-bold text-xl tracking-tight text-text">
        NeoCash
      </a>
      <span class="text-text-muted/40 hidden md:inline">|</span>
      <a href="/docs/" class="hidden md:inline font-mono text-xs text-accent uppercase tracking-[0.15em] hover:text-accent-hover transition-colors">
        Documentation
      </a>
    </div>

    <div class="flex items-center gap-4">
      <button
        id="docs-search-btn"
        class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-[#e5e3dc] text-text-muted text-sm hover:border-accent/40 transition-colors cursor-pointer"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="hidden sm:inline">Search</span>
        <kbd class="hidden md:inline text-xs text-text-muted/60 bg-bg-alt px-1.5 py-0.5 rounded border border-[#e5e3dc]">⌘K</kbd>
      </button>
      <a
        href="/"
        class="text-sm text-text-muted hover:text-accent transition-colors"
      >
        ← Back to Site
      </a>
    </div>
  </div>
</nav>
