---
import '../../styles/global.css';
import '../../styles/docs.css';
import DocsNav from '../../components/docs/DocsNav.astro';
import DocsSearch from '../../components/docs/DocsSearch.tsx';
import { docsNav } from '../../data/docs-navigation';

const title = 'NeoCash Documentation';
const description = 'Complete guide to NeoCash — privacy-first AI wealth management. Covers chat, goals, dashboard, signals, memory, documents, agents, and developer API reference.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf9f5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text">
    <DocsNav />
    <DocsSearch client:idle />

    <div class="mx-auto max-w-[1400px] px-6 py-12">
      <!-- Hero -->
      <div class="max-w-2xl mb-12">
        <h1 class="font-display text-4xl font-bold mb-4">Documentation</h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Everything you need to know about NeoCash — from getting started to building custom integrations.
        </p>
      </div>

      <!-- Section cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {docsNav.map((section) => {
          const firstItem = section.items[0];
          const href = `/docs/${firstItem.slug.endsWith('/index') ? firstItem.slug.slice(0, -'/index'.length) : firstItem.slug}/`;
          return (
            <a
              href={href}
              class="group block p-6 rounded-xl border border-[#e5e3dc] hover:border-accent/40 bg-bg hover:bg-bg-alt/50 transition-all duration-200"
            >
              <h2 class="font-display text-lg font-bold mb-2 group-hover:text-accent transition-colors">
                {section.label}
              </h2>
              <p class="text-sm text-text-muted mb-3">
                {section.items.length} {section.items.length === 1 ? 'page' : 'pages'}
              </p>
              <ul class="space-y-1">
                {section.items.slice(0, 4).map((item) => (
                  <li class="text-sm text-text-muted/80">{item.label}</li>
                ))}
                {section.items.length > 4 && (
                  <li class="text-sm text-accent">+{section.items.length - 4} more</li>
                )}
              </ul>
            </a>
          );
        })}
      </div>

      <!-- Persona guide -->
      <div class="mt-16 max-w-3xl">
        <h2 class="font-display text-2xl font-bold mb-6">Choose Your Path</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="p-5 rounded-lg border border-blue-200 bg-blue-50/50">
            <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full border border-blue-200 bg-blue-50 text-blue-700 mb-3">General</span>
            <h3 class="font-body font-semibold mb-1">New to NeoCash?</h3>
            <p class="text-sm text-text-muted mb-3">Start with the basics — installation, first chat, and interface tour.</p>
            <a href="/docs/getting-started/installation/" class="text-sm text-accent hover:text-accent-hover transition-colors font-medium">Get Started →</a>
          </div>
          <div class="p-5 rounded-lg border border-purple-200 bg-purple-50/50">
            <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full border border-purple-200 bg-purple-50 text-purple-700 mb-3">Power User</span>
            <h3 class="font-body font-semibold mb-1">Ready to Go Deeper?</h3>
            <p class="text-sm text-text-muted mb-3">Learn about goals, signals, memory, and dashboard customization.</p>
            <a href="/docs/goals/categories/" class="text-sm text-accent hover:text-accent-hover transition-colors font-medium">Explore Features →</a>
          </div>
          <div class="p-5 rounded-lg border border-emerald-200 bg-emerald-50/50">
            <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full border border-emerald-200 bg-emerald-50 text-emerald-700 mb-3">Developer</span>
            <h3 class="font-body font-semibold mb-1">Build & Extend</h3>
            <p class="text-sm text-text-muted mb-3">Architecture, hooks, tools, API routes, and type reference.</p>
            <a href="/docs/developer/architecture/" class="text-sm text-accent hover:text-accent-hover transition-colors font-medium">Read API Docs →</a>
          </div>
        </div>
      </div>
    </div>

    <footer class="border-t border-[#e5e3dc] py-6 text-center text-sm text-text-muted">
      <div class="mx-auto max-w-[1400px] px-6">
        NeoCash Documentation &middot;
        <a href="/" class="text-accent hover:text-accent-hover transition-colors">Back to Site</a>
      </div>
    </footer>
  </body>
</html>
