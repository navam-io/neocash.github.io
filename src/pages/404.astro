---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — NeoCash">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="text-8xl font-display font-bold text-accent/20 mb-4">404</p>
      <h1 class="font-display text-3xl font-bold text-text mb-3">Page Not Found</h1>
      <p class="text-text-muted mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center bg-accent text-white rounded-full px-6 py-2.5 text-sm font-medium hover:bg-accent-hover transition-colors duration-200"
      >
        Back to Home
      </a>
    </div>
  </div>
</Layout>
