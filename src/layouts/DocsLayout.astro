---
import '../styles/global.css';
import '../styles/docs.css';
import DocsNav from '../components/docs/DocsNav.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsTOC from '../components/docs/DocsTOC.astro';
import DocsPrevNext from '../components/docs/DocsPrevNext.astro';
import DocsBreadcrumbs from '../components/docs/DocsBreadcrumbs.astro';
import DocsPersonaBadge from '../components/docs/DocsPersonaBadge.astro';
import DocsSearch from '../components/docs/DocsSearch.tsx';

interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  personas?: ('general-user' | 'power-user' | 'developer')[];
  currentSlug: string;
  headings: TocItem[];
}

const { title, description, personas, currentSlug, headings } = Astro.props;
const pageTitle = `${title} — NeoCash Docs`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf9f5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />

    <title>{pageTitle}</title>
  </head>
  <body class="bg-bg text-text">
    <DocsNav />
    <DocsSearch client:idle />

    <div class="mx-auto max-w-[1400px] px-4 sm:px-6">
      <!-- Mobile sidebar toggle -->
      <div class="lg:hidden py-3 border-b border-[#e5e3dc]">
        <button
          id="open-sidebar"
          class="flex items-center gap-2 text-sm text-text-muted hover:text-accent transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          Menu
        </button>
      </div>

      <div class="flex gap-8 py-8">
        <DocsSidebar currentSlug={currentSlug} />

        <!-- Main content -->
        <main class="min-w-0 flex-1 max-w-3xl">
          <DocsBreadcrumbs currentSlug={currentSlug} pageTitle={title} />
          {personas && personas.length > 0 && <DocsPersonaBadge personas={personas} />}

          <article class="docs-prose">
            <h1>{title}</h1>
            <slot />
          </article>

          <DocsPrevNext currentSlug={currentSlug} />
        </main>

        <DocsTOC headings={headings} />
      </div>
    </div>

    <footer class="border-t border-[#e5e3dc] py-6 text-center text-sm text-text-muted">
      <div class="mx-auto max-w-[1400px] px-6">
        NeoCash Documentation &middot;
        <a href="/" class="text-accent hover:text-accent-hover transition-colors">Back to Site</a>
      </div>
    </footer>
  </body>
</html>
